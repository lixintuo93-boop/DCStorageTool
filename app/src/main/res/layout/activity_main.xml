<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 当前账号信息 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前账号"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_val_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#1B5E20"
                    android:textIsSelectable="true"
                    android:padding="6dp"
                    android:background="#E8F5E9"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_val_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#4E342E"
                    android:textIsSelectable="true"
                    android:padding="6dp"
                    android:background="#EFEBE9"
                    android:layout_marginTop="4dp"
                    android:maxLines="5"
                    android:ellipsize="end"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session"
                    android:textSize="10sp"
                    android:textColor="#607D8B"
                    android:layout_marginTop="6dp"/>
                <TextView
                    android:id="@+id/tv_val_uni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#E65100"
                    android:textIsSelectable="true"
                    android:padding="6dp"
                    android:background="#FFF3E0"
                    android:maxLines="3"
                    android:ellipsize="end"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 当前设备信息 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前设备信息"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp"/>

                <!-- DCStorage -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DCStorage（基准）"
                    android:textSize="10sp"
                    android:textColor="#607D8B"/>
                <TextView
                    android:id="@+id/tv_val_db"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="读取中..."
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#2E7D32"
                    android:textIsSelectable="true"
                    android:padding="6dp"
                    android:background="#F1F8E9"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"/>

                <!-- .DC 文件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=".DC 文件"
                    android:textSize="10sp"
                    android:textColor="#607D8B"
                    android:layout_marginTop="6dp"/>
                <TextView
                    android:id="@+id/tv_val_dc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#1565C0"
                    android:textIsSelectable="true"
                    android:padding="6dp"
                    android:background="#E3F2FD"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 新 UUID / Token 输入 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新 UUID / Token / 登录JSON（换行分隔，自动识别）"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_new_uuid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="粘贴 UUID/Token/登录JSON&#10;换行分隔，自动识别类型&#10;完整登录JSON自动迁移账号"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:inputType="textMultiLine"
                    android:background="@null"
                    android:minLines="5"
                    android:maxLines="10"
                    android:gravity="top"
                    android:paddingVertical="4dp"
                    android:scrollbars="vertical"/>

                <!-- 清空 / 粘贴 按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="4dp">
                    <Button
                        android:id="@+id/btn_paste"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:minWidth="48dp"
                        android:paddingHorizontal="6dp"
                        android:text="粘贴"
                        android:textSize="10sp"
                        android:backgroundTint="#78909C"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                    <Button
                        android:id="@+id/btn_clear_input"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:minWidth="48dp"
                        android:paddingHorizontal="6dp"
                        android:text="清空"
                        android:textSize="10sp"
                        android:backgroundTint="#90A4AE"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"/>

                <TextView
                    android:id="@+id/tv_input_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#757575"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="7sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 读取 + 写入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <Button
                android:id="@+id/btn_generate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="读  取"
                android:textSize="13sp"
                android:backgroundTint="#2E7D32"
                android:layout_marginEnd="6dp"/>
            <Button
                android:id="@+id/btn_write"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="写  入"
                android:textSize="13sp"
                android:letterSpacing="0.1"
                android:backgroundTint="#C62828"/>
        </LinearLayout>

        <!-- 调试日志 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="调试日志"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1565C0"/>
                    <Button
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="56dp"
                        android:paddingHorizontal="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="清空"
                        android:textSize="11sp"
                        android:backgroundTint="#90A4AE"
                        android:layout_marginEnd="6dp"/>
                    <Button
                        android:id="@+id/btn_copy_log"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="56dp"
                        android:paddingHorizontal="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="复制"
                        android:textSize="11sp"
                        android:backgroundTint="#455A64"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_debug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:maxHeight="320dp"
                    android:padding="8dp"
                    android:background="#0E1726"
                    android:textColor="#B8F2C9"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false"
                    android:text=""/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
