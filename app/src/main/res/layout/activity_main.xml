<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 当前 UUID -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前 UUID"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/tv_decrypted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="读取中..."
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textColor="#2E7D32"
                    android:textIsSelectable="true"
                    android:padding="8dp"
                    android:background="#F1F8E9"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 新 UUID -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新 UUID"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_new_uuid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="粘贴 / 输入新的 UUID"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:background="@null"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:paddingVertical="4dp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeStepGranularity="1sp"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"/>

                <TextView
                    android:id="@+id/tv_input_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#757575"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="7sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 生成 + 写入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <Button
                android:id="@+id/btn_generate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="随机 UUID"
                android:textSize="13sp"
                android:backgroundTint="#546E7A"
                android:layout_marginEnd="6dp"/>
            <Button
                android:id="@+id/btn_write"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="写  入"
                android:textSize="13sp"
                android:letterSpacing="0.1"
                android:backgroundTint="#C62828"/>
        </LinearLayout>

        <!-- 调试日志 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="调试日志"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1565C0"/>
                    <Button
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="56dp"
                        android:paddingHorizontal="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="清空"
                        android:textSize="11sp"
                        android:backgroundTint="#90A4AE"
                        android:layout_marginEnd="6dp"/>
                    <Button
                        android:id="@+id/btn_copy_log"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="56dp"
                        android:paddingHorizontal="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="复制"
                        android:textSize="11sp"
                        android:backgroundTint="#455A64"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_debug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:maxHeight="320dp"
                    android:padding="8dp"
                    android:background="#0E1726"
                    android:textColor="#B8F2C9"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false"
                    android:text=""/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
