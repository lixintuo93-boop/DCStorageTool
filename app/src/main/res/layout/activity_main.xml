<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DCStorage 查看 / 修改工具"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="16dp" />

        <!-- 配置卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hospital ID" android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_hospital_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:background="@android:drawable/editbox_background" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="存储 Key" android:textStyle="bold" android:layout_marginTop="8dp" />
                <EditText
                    android:id="@+id/et_db_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/editbox_background" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 读取按钮 -->
        <Button
            android:id="@+id/btn_read"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="读取当前值"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="12dp" />

        <!-- 当前值卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="加密原文（Base64）" android:textStyle="bold" android:textColor="#555" />
                <TextView
                    android:id="@+id/tv_raw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#E65100"
                    android:layout_marginTop="4dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="解密结果（UUID）" android:textStyle="bold" android:textColor="#555"
                    android:layout_marginTop="10dp"/>
                <TextView
                    android:id="@+id/tv_decrypted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textColor="#1B5E20"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 修改卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="新的 UUID 值" android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_new_uuid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入或随机生成 UUID"
                    android:fontFamily="monospace"
                    android:background="@android:drawable/editbox_background" />

                <Button
                    android:id="@+id/btn_generate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="随机生成 UUID"
                    android:backgroundTint="#546E7A"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btn_write"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="写入新值"
                    android:backgroundTint="#B71C1C"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 状态栏 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="初始化中..."
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:textColor="#0D47A1" />

    </LinearLayout>
</ScrollView>
